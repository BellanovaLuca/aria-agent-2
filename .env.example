# ── LiveKit Cloud ────────────────────────────────────────────────────────────
# Ottieni le credenziali da: https://cloud.livekit.io → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# ── Google Gemini Live (LLM + STT + TTS) ─────────────────────────────────────
# Ottieni la chiave da: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key

# ── Twilio SIP (chiamate telefoniche) ────────────────────────────────────────
# Numero acquistato su Twilio in formato E.164 (es. +390212345678)
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Credenziali libere — usate sia nel TwiML Bin Twilio che nel trunk LiveKit
SIP_USERNAME=password-reset-agent
SIP_PASSWORD=change-me-strong-password

# ── Servizi interni ───────────────────────────────────────────────────────────
USER_SERVICE_URL=http://localhost:8001
EMAIL_SERVICE_URL=http://localhost:8002
KNOWLEDGE_SERVICE_URL=http://localhost:8003
CHAT_SERVICE_URL=http://localhost:8004
TICKET_SERVICE_URL=http://localhost:8005
ANALYTICS_SERVICE_URL=http://localhost:8006
EMAIL_POLL_INTERVAL=10
AGENT_EMAIL=agent@password-reset.local

# Modelli Gemini per chat (function calling) e analisi post-chiamata.
CHAT_MODEL=gemini-2.5-flash
ANALYSIS_MODEL=gemini-2.5-flash

# ── Knowledge base (RAG) ──────────────────────────────────────────────────────
# Qdrant gira in locale embedded (cartella su disco): nessuna configurazione
# necessaria. Per usare un server Qdrant esterno o Qdrant Cloud, imposta QDRANT_URL
# (es. http://localhost:6333) e verrà usato al posto dello storage locale.
# QDRANT_URL=
# Anti-abuso sblocco utenze: massimo sblocchi riusciti per utente in 24h.
MAX_UNLOCKS_24H=2

# ── Sicurezza interna ─────────────────────────────────────────────────────────
# Chiave condivisa che autentica le chiamate tra i processi locali
# (voice agent, email processor, proxy Vite → user_service / email_service).
# Genera un valore forte con: openssl rand -hex 32
INTERNAL_API_KEY=change-me-openssl-rand-hex-32
